function handleStartEditingMessage(message: Message) {
  editingMessage.value = message;
  text.value = message.deletedForEveryoneAt ? '' : message.text;
  replyToMessage.value = null;
}

function cancelEditingMessage() {
  editingMessage.value = null;
  text.value = '';
  errorText.value = '';
}

async function saveEditedMessage() {
  if (!activeConversationId.value || !editingMessage.value) return;
  if (!text.value.trim()) return;

  const socket = getSocket();
  console.log('[sendMessage] socket', {
    exists: !!socket,
    activeConversationId: activeConversationId.value,
    text: text.value,
  });
  if (!socket) return;

  const conversationId = activeConversationId.value;
  const messageId = editingMessage.value.id;
  const messageText = text.value.trim();

  socket.emit(
    'message:edit',
    {
      conversationId,
      messageId,
      text: messageText,
    },
    async (ack: any) => {
      if (!ack?.ok) {
        errorText.value = ack?.error || 'Не удалось сохранить изменения';
        return;
      }

      editingMessage.value = null;
      text.value = '';
      emitTypingStop();

      if (activeConversationId.value !== conversationId) return;
      await loadConversations();
    }
  );
}

async function sendMessage() {
  console.log('[sendMessage]', {
    activeConversationId: activeConversationId.value,
    editingMessageId: editingMessage.value?.id || null,
    text: text.value,
    canSendMessage: canSendMessage.value,
  });

  if (sendBlockedReason.value) {
    errorText.value = sendBlockedReason.value;
    return;
  }

  if (editingMessage.value) {
    await saveEditedMessage();
    return;
  }

  if (!activeConversationId.value || !text.value.trim()) {
    console.log('[sendMessage] guard blocked', {
      text: text.value,
      trimmed: text.value.trim(),
      activeConversationId: activeConversationId.value,
    });
    return;
  }

  const socket = getSocket();
  console.log('[sendMessage] socket check', {
    exists: !!socket,
    connected: socket?.connected,
    activeConversationId: activeConversationId.value,
    trimmedText: text.value.trim(),
  });
  if (!socket) {
    errorText.value = 'Нет подключения к серверу';
    return;
  }

  if (!socket.connected) {
    errorText.value = 'Соединение с сервером потеряно. Попробуйте подождать или обновить страницу.';
    socket.connect();
    return;
  }

  const conversationId = activeConversationId.value;
  const messageText = text.value.trim();
  const replySnapshot = replyToMessage.value
    ? {
        id: replyToMessage.value.id,
        userId: replyToMessage.value.userId,
        username: replyToMessage.value.username,
        text: getMessagePreviewText(replyToMessage.value),
        createdAt: replyToMessage.value.createdAt,
        attachmentPreview: replyToMessage.value.attachments?.[0] || null,
      }
    : null;

  isChatNearBottom.value = true;
  pendingNewMessagesCount.value = 0;
  firstUnreadMessageId.value = null;

  const currentUsernameValue = currentUser.value?.username || 'You';
  const { clientId, optimisticMessage } = createOptimisticMessage({
    conversationId,
    text: messageText,
    username: currentUsernameValue,
    replyTo: replySnapshot,
  });

  insertOptimisticMessage(optimisticMessage);

  text.value = '';
  emitTypingStop();
  replyToMessage.value = null;

  console.log('[send] before emit', {
    connected: socket.connected,
    conversationId,
    clientId,
    text: messageText,
    replyToMessageId: replySnapshot?.id || null,
  });

  let ackHandled = false;
  const ackTimeout = window.setTimeout(() => {
    if (ackHandled) return;
    console.warn('[send] ack timeout', { conversationId, clientId });
    markOptimisticMessageFailed(optimisticMessage.id);
    errorText.value = 'Сервер не подтвердил отправку сообщения';
  }, 8000);

  socket.emit(
    'message:send',
    {
      clientId,
      conversationId,
      text: messageText,
      replyToMessageId: replySnapshot?.id || null,
    },
    async (ack: any) => {
      ackHandled = true;
      window.clearTimeout(ackTimeout);
      console.log('[send] ack received', ack);

      if (!ack?.ok) {
        markOptimisticMessageFailed(optimisticMessage.id);
        errorText.value = ack?.error || 'Message send failed';
        return;
      }

      if (ack?.message) {
        reconcileOptimisticMessage({
          ...ack.message,
          clientId: ack.clientId || ack.message.clientId || clientId,
        });
      }

      if (activeConversationId.value !== conversationId) return;

      await markConversationRead(conversationId);

      if (activeConversationId.value !== conversationId) return;
      await loadConversations();
    }
  );
}

async function startApp() {
  try {
    errorText.value = '';

    if (!token.value) {
      const restored = await restoreSession();
      saveSession(restored.token, { username: restored.user.username });
    } else {
      setToken(token.value);
    }

    mode.value = 'app';

    await loadUsers();
    await loadConversations();

    const activeToken = token.value;
    if (!activeToken) {
      throw new Error('No access token available after session restore');
    }

    const socket = connectSocket(activeToken);

    socket.off('users:online');
    socket.off('message:new');
    socket.off('message:read');
    socket.off('message:edited');
    socket.off('message:deleted');
    socket.off('conversation:updated');
    socket.off('typing:update');
    socket.off('connect');
    socket.off('connect_error');

    socket.on('connect', () => {
      const cid = activeConversationId.value;
      if (cid) {
        socket.emit('conversation:join', { conversationId: cid });
        loadConversations();
      }
    });

    socket.on('connect_error', async (error: any) => {
      const message = String(error?.message || '');
      console.error('[App] socket connect_error', message);

      if (message !== 'Unauthorized') return;

      try {
        const restored = await restoreSession();
        if (!restored?.token) {
          clearSession();
          return;
        }

        saveSession(restored.token, { username: restored.user.username });
        const refreshedSocket = connectSocket(restored.token, true);

        refreshedSocket.off('connect');
        refreshedSocket.on('connect', () => {
          const cid = activeConversationId.value;
          if (cid) {
            refreshedSocket.emit('conversation:join', { conversationId: cid });
            loadConversations();
          }
        });
      } catch {
        clearSession();
      }
    });

    socket.on('users:online', (payload: { userIds: string[] }) => {
      onlineUserIds.value = payload.userIds || [];
    });

    socket.on('typing:update', (payload: { conversationId: string; username: string; isTyping: boolean }) => {
      if (payload.conversationId !== activeConversationId.value) return;

      if (payload.isTyping) {
        typingText.value = `${payload.username} печатает...`;
      } else {
        typingText.value = '';
      }
    });

    // Realtime read-receipt: update isRead on the current user's messages when
    // another participant marks the conversation as read.
    socket.on('message:edited', (payload: { conversationId: string; message: Message }) => {
      if (!payload.conversationId || !payload.message) return;
      if (payload.conversationId !== activeConversationId.value) return;

      messages.value = mergeMessagesStable(messages.value, [payload.message]);

      if (replyToMessage.value?.id === payload.message.id) {
        replyToMessage.value = { ...replyToMessage.value, ...payload.message };
      }

      if (editingMessage.value?.id === payload.message.id) {
        editingMessage.value = null;
      }
    });

    socket.on('message:read', (payload: { conversationId: string; readAt: string }) => {
      if (payload.conversationId !== activeConversationId.value) return;

      const readAtMs = new Date(payload.readAt).getTime();
      messages.value = messages.value.map((m) => {
        if (m.username === currentUser.value?.username && !m.isRead) {
          if (new Date(m.createdAt).getTime() <= readAtMs) {
            return { ...m, isRead: true };
          }
        }
        return m;
      });
    });

    socket.on(
      'message:deleted',
      (payload: {
        conversationId: string;
        messageIds: string[];
        mode: 'self' | 'everyone';
        actorUserId: string;
      }) => {
        if (payload.conversationId !== activeConversationId.value) return;
        if (!Array.isArray(payload.messageIds) || payload.messageIds.length === 0) return;

        if (payload.mode === 'self') {
          messages.value = messages.value.filter((message) => !payload.messageIds.includes(message.id));

          if (pinnedMessage.value && payload.messageIds.includes(pinnedMessage.value.id)) {
            pinnedMessage.value = null;
          }
          return;
        }

        messages.value = messages.value.map((message) => {
          if (!payload.messageIds.includes(message.id)) return message;
          return {
            ...message,
            text: 'Сообщение удалено',
            replyTo: null,
            attachments: [],
            forwardedFromMessageId: null,
            forwardedFromUserId: null,
            forwardedFromUsername: null,
            deletedForEveryoneAt: new Date().toISOString(),
          };
        });

        if (pinnedMessage.value && payload.messageIds.includes(pinnedMessage.value.id)) {
          pinnedMessage.value = {
            ...pinnedMessage.value,
            text: 'Сообщение удалено',
            replyTo: null,
            attachments: [],
            forwardedFromMessageId: null,
            forwardedFromUserId: null,
            forwardedFromUsername: null,
            deletedForEveryoneAt: new Date().toISOString(),
          };
        }
      }
    );

    socket.on('message:new', async (payload: { message: Message }) => {
      const isActiveChatMessage = payload.message.conversationId === activeConversationId.value;

      if (isActiveChatMessage) {
        await appendIncomingMessage(payload.message);
      }

      await loadConversations();
    });

    socket.on('conversation:updated', async () => {
      await loadConversations();
    });

    // Do not auto-open any conversation on page load/refresh.
    // The user must explicitly click a conversation in the sidebar.
  } catch (error: any) {
    if (error?.response?.status === 401) {
      logout();
      return;
    }

    errorText.value = error?.response?.data?.error || error?.message || 'Failed to start app';
    mode.value = 'auth';
  }
}

async function logout() {
  emitTypingStop();

  try {
    await logoutRequest();
  } catch {}

  clearSession();
  disconnectSocket();

  mode.value = 'auth';
  users.value = [];
  conversations.value = [];
  activeConversationId.value = null;
  messages.value = [];
  participants.value = [];
  text.value = '';
  loadingOlder.value = false;
  hasMoreOlder.value = true;
  hasMoreNewer.value = false;
  loadingNewer.value = false;
  isJumpMode.value = false;
  isChatNearBottom.value = true;
  pendingNewMessagesCount.value = 0;
  firstUnreadMessageId.value = null;
  replyToMessage.value = null;
  pinnedMessage.value = null;
  onlineUserIds.value = [];
  typingText.value = '';
  searchQuery.value = '';
  errorText.value = '';
  groupTitle.value = '';
  selectedGroupUserIds.value = [];
  channelTitle.value = '';
  isMenuOpen.value = false;
  isChatInfoModalOpen.value = false;
  isCreateGroupModalOpen.value = false;
  isCreateChannelModalOpen.value = false;
  isForwardModalOpen.value = false;
  forwardSearchQuery.value = '';
  conversationCache.clear();
  conversationLoadTokens.clear();
  conversationContextTokens.clear();
}

startApp().catch((error: any) => {
  if (error?.response?.status === 401) {
    logout();
    return;
  }

  errorText.value = error?.response?.data?.error || error?.message || 'Failed to restore session';
  mode.value = 'auth';
});
</script>

