async function uploadAttachment(file: File): Promise<MessageAttachment> {
  const formData = new FormData();
  formData.append('file', file);

  const { data } = await api.post('/uploads', formData, {
    headers: {
      'Content-Type': 'multipart/form-data',
    },
  });

  return data.attachment as MessageAttachment;
}

async function handleAttachPicked(payload: { file: File; category: 'media' | 'audio' | 'file' }) {
  if (!activeConversationId.value) return;

  if (sendBlockedReason.value) {
    errorText.value = sendBlockedReason.value;
    return;
  }

  if (editingMessage.value) {
    errorText.value = 'Нельзя прикреплять файл во время редактирования сообщения';
    return;
  }

  const socket = getSocket();
  if (!socket) {
    errorText.value = 'Нет подключения к серверу';
    return;
  }

  if (!socket.connected) {
    errorText.value = 'Соединение с сервером потеряно. Попробуйте подождать или обновить страницу.';
    socket.connect();
    return;
  }

  try {
    errorText.value = '';

    const attachment = await uploadAttachment(payload.file);

    const conversationId = activeConversationId.value;
    const messageText = text.value.trim();
    const replySnapshot = replyToMessage.value
      ? {
          id: replyToMessage.value.id,
          userId: replyToMessage.value.userId,
          username: replyToMessage.value.username,
          text: getMessagePreviewText(replyToMessage.value),
          createdAt: replyToMessage.value.createdAt,
        }
      : null;

    isChatNearBottom.value = true;
    pendingNewMessagesCount.value = 0;
    firstUnreadMessageId.value = null;

    const currentUsernameValue = currentUser.value?.username || 'You';
    const { clientId, optimisticMessage } = createOptimisticMessage({
      conversationId,
      text: messageText,
      username: currentUsernameValue,
      replyTo: replySnapshot,
      attachments: [attachment],
    });

    insertOptimisticMessage(optimisticMessage);

    text.value = '';
    emitTypingStop();
    replyToMessage.value = null;

    let ackHandled = false;
    const ackTimeout = window.setTimeout(() => {
      if (ackHandled) return;
      markOptimisticMessageFailed(optimisticMessage.id);
      errorText.value = 'Сервер не подтвердил отправку сообщения';
    }, 8000);

    socket.emit(
      'message:send',
      {
        clientId,
        conversationId,
        text: messageText,
        replyToMessageId: replySnapshot?.id || null,
        attachments: [attachment],
      },
      async (ack: any) => {
        ackHandled = true;
        window.clearTimeout(ackTimeout);

        if (!ack?.ok) {
          markOptimisticMessageFailed(optimisticMessage.id);
          errorText.value = ack?.error || 'Message send failed';
          return;
        }

        if (ack?.message) {
          reconcileOptimisticMessage({
            ...ack.message,
            clientId: ack.clientId || ack.message.clientId || clientId,
          });
        }

        if (activeConversationId.value !== conversationId) return;
        await markConversationRead(conversationId);

        if (activeConversationId.value !== conversationId) return;
        await loadConversations();
      }
    );
  } catch (error: any) {
    console.error('attachment upload/send error', error);
    errorText.value = error?.response?.data?.error || 'Не удалось загрузить файл';
  }
}

