}

async function uploadAttachment(file: File): Promise<MessageAttachment> {
  const formData = new FormData();
  formData.append('file', file);

  const { data } = await api.post('/uploads', formData, {
    headers: {
      'Content-Type': 'multipart/form-data',
    },
  });

  return data.attachment as MessageAttachment;
}

async function handleAttachPicked(payload: {
  file: File;
  category: 'media' | 'audio' | 'file';
}) {
  const file = payload?.file;
  if (!file || !activeConversationId.value) return;

  if (sendBlockedReason.value) {
    errorText.value = sendBlockedReason.value;
    return;
  }

  const socket = getSocket();
  if (!socket) {
    errorText.value = 'Нет подключения к серверу';
    return;
  }

  if (!socket.connected) {
    errorText.value = 'Соединение с сервером потеряно. Попробуйте подождать или обновить страницу.';
    socket.connect();
    return;
  }

  const conversationId = activeConversationId.value;
  const replySnapshot = replyToMessage.value
    ? {
        id: replyToMessage.value.id,
        userId: replyToMessage.value.userId,
        username: replyToMessage.value.username,
        text: getMessagePreviewText(replyToMessage.value),
        createdAt: replyToMessage.value.createdAt,
        attachmentPreview: replyToMessage.value.attachments?.[0] || null,
      }
    : null;

  const kind: 'image' | 'video' | 'audio' | 'file' =
    file.type.startsWith('image/')
      ? 'image'
      : file.type.startsWith('video/')
      ? 'video'
      : file.type.startsWith('audio/')
      ? 'audio'
      : 'file';

  const tempAttachmentId = generateClientId();
  const localUrl = URL.createObjectURL(file);

  const optimisticAttachment: MessageAttachment = {
    tempId: tempAttachmentId,
    kind,
    originalName: file.name,
    storedName: file.name,
    mimeType: file.type || 'application/octet-stream',
    sizeBytes: file.size || 0,
    relativeUrl: localUrl,
    uploadStatus: 'uploading',
    uploadProgress: 0,
  };

  const currentUsernameValue = currentUser.value?.username || 'You';
  const { clientId, optimisticMessage } = createOptimisticMessage({
    conversationId,
    text: '',
    username: currentUsernameValue,
    replyTo: replySnapshot,
    attachments: [optimisticAttachment],
  });

  isChatNearBottom.value = true;
  pendingNewMessagesCount.value = 0;
  firstUnreadMessageId.value = null;

  insertOptimisticMessage(optimisticMessage);
  replyToMessage.value = null;
  emitTypingStop();

  try {
    const formData = new FormData();
    formData.append('file', file);

    const uploadResponse = await api.post('/uploads', formData, {
      headers: {
        'Content-Type': 'multipart/form-data',
      },
      onUploadProgress: (event: any) => {
        const total = Number(event?.total || file.size || 0);
        const loaded = Number(event?.loaded || 0);
        const percent =
          total > 0 ? Math.min(100, Math.max(0, Math.round((loaded / total) * 100))) : 0;

        updateOptimisticAttachmentProgress(
          optimisticMessage.id,
          tempAttachmentId,
          percent
        );
      },
    });

    const uploaded = uploadResponse?.data?.attachment;
    if (!uploaded) {
      throw new Error('Не удалось загрузить файл');
    }

    let ackHandled = false;
    const ackTimeout = window.setTimeout(() => {
      if (ackHandled) return;
      markOptimisticMessageFailed(optimisticMessage.id);
      markOptimisticAttachmentFailed(optimisticMessage.id, tempAttachmentId);
      errorText.value = 'Сервер не подтвердил отправку сообщения';
    }, 8000);

    socket.emit(
      'message:send',
      {
        clientId,
        conversationId,
        text: '',
        replyToMessageId: replySnapshot?.id || null,
        attachments: [uploaded],
      },
      async (ack: any) => {
        ackHandled = true;
        window.clearTimeout(ackTimeout);

        if (!ack?.ok) {
          markOptimisticMessageFailed(optimisticMessage.id);
          markOptimisticAttachmentFailed(optimisticMessage.id, tempAttachmentId);
          errorText.value = ack?.error || 'Message send failed';
          return;
        }

        if (ack?.message) {
          reconcileOptimisticMessage({
            ...ack.message,
            clientId: ack.clientId || ack.message.clientId || clientId,
          });
        }

        URL.revokeObjectURL(localUrl);

        if (activeConversationId.value !== conversationId) return;
        await markConversationRead(conversationId);

        if (activeConversationId.value !== conversationId) return;
        await loadConversations();
      }
    );
  } catch (error: any) {
    markOptimisticMessageFailed(optimisticMessage.id);
    markOptimisticAttachmentFailed(optimisticMessage.id, tempAttachmentId);
    errorText.value =
      error?.response?.data?.error ||
      error?.message ||
      'Не удалось загрузить файл';
  }
}


