function compareMessagesAsc(a: Message, b: Message) {
  if (typeof a.seq === 'number' && typeof b.seq === 'number') {
    return a.seq - b.seq;
  }

  if (a.createdAt < b.createdAt) return -1;
  if (a.createdAt > b.createdAt) return 1;
  return a.id.localeCompare(b.id);
}

function mergeMessagesStable(current: Message[], incoming: Message[]) {
  const byId = new Map<string, Message>();

  for (const message of current) {
    byId.set(message.id, message);
  }

  for (const message of incoming) {
    const prev = byId.get(message.id);

    if (!prev) {
      byId.set(message.id, message);
      continue;
    }

    byId.set(message.id, {
      ...prev,
      ...message,
      attachments:
        Array.isArray(message.attachments) && message.attachments.length > 0
          ? message.attachments
          : (prev.attachments || []),
      replyTo:
        message.replyTo
          ? {
              ...(prev.replyTo || {}),
              ...message.replyTo,
              attachmentPreview:
                message.replyTo.attachmentPreview !== undefined
                  ? message.replyTo.attachmentPreview
                  : prev.replyTo?.attachmentPreview,
            }
          : message.replyTo === null
            ? null
            : prev.replyTo,
    });
  }

  return Array.from(byId.values()).sort(compareMessagesAsc);
}

function generateClientId() {
  if (typeof globalThis !== 'undefined' && globalThis.crypto && typeof globalThis.crypto.randomUUID === 'function') {
    return globalThis.crypto.randomUUID();
  }

  return `client-${Date.now()}-${Math.random().toString(16).slice(2)}-${Math.random().toString(16).slice(2)}`;
}

function getMessagePreviewText(message: Pick<Message, 'text' | 'attachments'>) {
  const plain = (message.text || '').trim();
  if (plain) return plain;

  const first = message.attachments?.[0];
  if (!first) return '';

  if (first.kind === 'image') return '🖼 Фото';
  if (first.kind === 'video') return '🎬 Видео';
  if (first.kind === 'audio') return '🎵 Аудио';
  return '📎 Файл';
}

function createOptimisticMessage(params: {
  conversationId: string;
  text: string;
  username: string;
  replyTo: MessageReply | null;
  attachments?: MessageAttachment[];
}) {
  const clientId = generateClientId();
  const now = new Date().toISOString();

  const optimisticMessage: Message = {
    id: `temp:${clientId}`,
    clientId,
    conversationId: params.conversationId,
    userId: 'self',
    username: params.username,
    text: params.text,
    createdAt: now,
    editedAt: null,
    isRead: false,
    status: 'sending',
    replyTo: params.replyTo,
    deletedForEveryoneAt: null,
    forwardedFromMessageId: null,
    forwardedFromUserId: null,
    forwardedFromUsername: null,
    attachments: params.attachments || [],
  };

  return { clientId, optimisticMessage };
}

function insertOptimisticMessage(message: Message) {
  messages.value = mergeMessagesStable(messages.value, [message]);
  scrollRevision.value += 1;
}

function markOptimisticMessageFailed(tempId: string) {
  messages.value = messages.value.map((message) =>
    message.id === tempId
      ? { ...message, status: 'failed' }
      : message
  );
}

function updateOptimisticAttachmentProgress(
  tempMessageId: string,
  tempAttachmentId: string,
  progress: number
) {
  messages.value = messages.value.map((message) => {
    if (message.id !== tempMessageId) return message;

    return {
      ...message,
      attachments: (message.attachments || []).map((attachment) =>
        (attachment.tempId || attachment.id) === tempAttachmentId
          ? {
              ...attachment,
              uploadStatus: 'uploading',
              uploadProgress: progress,
            }
          : attachment
      ),
    };
  });
}

function markOptimisticAttachmentFailed(
  tempMessageId: string,
  tempAttachmentId: string
) {
  messages.value = messages.value.map((message) => {
    if (message.id !== tempMessageId) return message;

    return {
      ...message,
      attachments: (message.attachments || []).map((attachment) =>
        (attachment.tempId || attachment.id) === tempAttachmentId
          ? {
              ...attachment,
              uploadStatus: 'failed',
            }
          : attachment
      ),
    };
  });
}

function reconcileOptimisticMessage(serverMessage: Message) {
  let optimisticIndex = -1;

  if (serverMessage.clientId) {
    optimisticIndex = messages.value.findIndex(
      (message) =>
        (message.status === 'sending' || message.status === 'failed') &&
        message.clientId === serverMessage.clientId
    );
  }

  if (optimisticIndex === -1) {
    optimisticIndex = messages.value.findIndex((message) => {
      if (message.status !== 'sending' && message.status !== 'failed') return false;
      if (message.username !== serverMessage.username) return false;
      if (message.conversationId !== serverMessage.conversationId) return false;
      if (message.text !== serverMessage.text) return false;

      const optimisticTime = new Date(message.createdAt).getTime();
      const serverTime = new Date(serverMessage.createdAt).getTime();
      return Math.abs(serverTime - optimisticTime) < 30000;
    });
  }

  if (optimisticIndex === -1) {
    messages.value = mergeMessagesStable(messages.value, [{ ...serverMessage, status: 'sent' }]);
    return;
  }

  const next = [...messages.value];
  next.splice(optimisticIndex, 1, { ...serverMessage, status: 'sent' });
  messages.value = mergeMessagesStable([], next);
}

function applyRealtimeMessageDeletedToList(
  list: Message[],
  deletedIds: Set<string>,
  mode: 'self' | 'everyone'
) {
  if (mode === 'self') {
    return list.filter((message) => !deletedIds.has(message.id));
  }

  return list.map((message) => {
    const isDeletedMessage = deletedIds.has(message.id);
    const isForwardedFromDeleted =
      !!message.forwardedFromMessageId && deletedIds.has(message.forwardedFromMessageId);

    let next = message;

    if (isDeletedMessage || isForwardedFromDeleted) {
      next = {
        ...next,
        text: 'Сообщение удалено',
        deletedForEveryoneAt: next.deletedForEveryoneAt || new Date().toISOString(),
        forwardedFromMessageId: null,
        forwardedFromUserId: null,
        forwardedFromUsername: null,
        replyTo: null,
        attachments: [],
        status: 'sent',
      };
    }

    if (next.replyTo && deletedIds.has(next.replyTo.id)) {
      next = {
        ...next,
        replyTo: {
          id: next.replyTo.id,
          userId: next.replyTo.userId,
          username: next.replyTo.username,
          text: 'Сообщение удалено',
          createdAt: next.replyTo.createdAt,
        },
      };
    }

    return next;
  });
}

function applyRealtimeMessageDeleted(params: {
  conversationId: string;
  messageIds: string[];
  mode: 'self' | 'everyone';
}) {
  const deletedIds = new Set(params.messageIds.filter(Boolean));
  if (deletedIds.size === 0) return;

  if (activeConversationId.value === params.conversationId) {
    messages.value = applyRealtimeMessageDeletedToList(
      messages.value,
      deletedIds,
      params.mode
    );
  }

  const cached = conversationCache.get(params.conversationId);
  if (cached) {
    conversationCache.set(params.conversationId, {
      ...cached,
      messages: applyRealtimeMessageDeletedToList(
        cached.messages,
        deletedIds,
        params.mode
      ),
    });
  }
}

