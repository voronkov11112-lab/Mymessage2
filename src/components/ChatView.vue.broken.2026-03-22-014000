type ViewerMediaItem = {
  key: string;
  kind: 'image' | 'video';
  src: string;
  mimeType: string;
  originalName: string;
  sizeBytes: number;
  senderUsername: string;
  createdAt: string;
  canDeleteForSelf: boolean;
  canDeleteForEveryone: boolean;
};

const mediaViewerVisible = ref(false);
const mediaViewerItems = ref<ViewerMediaItem[]>([]);
const mediaViewerStartIndex = ref(0);
const mediaViewerSourceMessage = ref<Message | null>(null);
const mediaViewerSourceAttachmentKey = ref<string | null>(null);

function messageMediaAttachments(message: Message) {
  return (message.attachments || []).filter(
    (attachment) => attachment.kind === 'image' || attachment.kind === 'video'
  );
}

function sameAttachment(a: MessageAttachment, b: MessageAttachment) {
  return (
    (!!a.id && !!b.id && a.id === b.id) ||
    (!!a.tempId && !!b.tempId && a.tempId === b.tempId) ||
    (!!a.relativeUrl && !!b.relativeUrl && a.relativeUrl === b.relativeUrl)
  );
}

function openMessageMediaViewer(message: Message, targetAttachment: MessageAttachment) {
  const media = messageMediaAttachments(message);
  if (media.length === 0) return;

  mediaViewerSourceMessage.value = message;
  mediaViewerItems.value = media.map((attachment, index) => ({
    key: attachment.id || attachment.tempId || `${attachment.relativeUrl}-${index}`,
    kind: attachment.kind as 'image' | 'video',
    src: attachmentUrl(attachment.relativeUrl),
    mimeType: attachment.mimeType,
    originalName: attachment.originalName,
    sizeBytes: attachment.sizeBytes,
    senderUsername: message.username,
    createdAt: message.createdAt,
    canDeleteForSelf: !message.deletedForEveryoneAt,
    canDeleteForEveryone: message.username === props.currentUsername && !message.deletedForEveryoneAt,
  }));

  const targetIndex = media.findIndex((attachment) => sameAttachment(attachment, targetAttachment));
  const resolvedIndex = targetIndex >= 0 ? targetIndex : 0;
  const resolvedAttachment = media[resolvedIndex] || null;

  mediaViewerStartIndex.value = resolvedIndex;
  mediaViewerSourceAttachmentKey.value = resolvedAttachment
    ? (resolvedAttachment.id || resolvedAttachment.tempId || resolvedAttachment.relativeUrl)
    : null;
  mediaViewerVisible.value = true;
}

function closeMediaViewer() {
  mediaViewerVisible.value = false;
  mediaViewerItems.value = [];
  mediaViewerStartIndex.value = 0;
  mediaViewerSourceMessage.value = null;
  mediaViewerSourceAttachmentKey.value = null;
}

function handleViewerReply() {
  if (!mediaViewerSourceMessage.value || !mediaViewerSourceAttachmentKey.value) return;
  emit('replyToSpecificAttachment', {
    message: mediaViewerSourceMessage.value,
    attachmentKey: mediaViewerSourceAttachmentKey.value,
  });
  closeMediaViewer();
}

function handleViewerForward() {
  if (!mediaViewerSourceMessage.value || !mediaViewerSourceAttachmentKey.value) return;
  emit('forwardSingleMessage', {
    message: mediaViewerSourceMessage.value,
    attachmentKey: mediaViewerSourceAttachmentKey.value,
  });
  closeMediaViewer();
}

function handleViewerDeleteSelf() {
  if (!mediaViewerSourceMessage.value || !mediaViewerSourceAttachmentKey.value) return;
  emit('deleteSpecificAttachment', {
    message: mediaViewerSourceMessage.value,
    attachmentKey: mediaViewerSourceAttachmentKey.value,
    mode: 'self',
  });
  closeMediaViewer();
}

function handleViewerDeleteEveryone() {
  if (!mediaViewerSourceMessage.value || !mediaViewerSourceAttachmentKey.value) return;
  emit('deleteSpecificAttachment', {
    message: mediaViewerSourceMessage.value,
    attachmentKey: mediaViewerSourceAttachmentKey.value,
    mode: 'everyone',
  });
  closeMediaViewer();
}

function handleViewerReport() {
  if (!mediaViewerSourceMessage.value) return;
  emit('reportMedia', mediaViewerSourceMessage.value);
}

function messageHasImageOnly(message: Message) {
  const attachments = message.attachments || [];
  if (attachments.length !== 1) return false;
  if (attachments[0].kind !== 'image') return false;
  return !message.text?.trim();
}

function messageHasAudioCardOnly(message: Message) {
  const attachments = message.attachments || [];
  if (attachments.length !== 1) return false;
  if (attachments[0].kind !== 'audio') return false;
  return !message.text?.trim();
}

const showAttachMenu = ref(false);
const attachMenuEl = ref<HTMLElement | null>(null);
const attachButtonEl = ref<HTMLElement | null>(null);
const mediaInput = ref<HTMLInputElement | null>(null);
const audioInput = ref<HTMLInputElement | null>(null);
const fileInput = ref<HTMLInputElement | null>(null);

type PendingMediaItem = {
  id: string;
  file: File;
  url: string;
  kind: 'image' | 'video';
};

const pendingMediaItems = ref<PendingMediaItem[]>([]);
const mediaBatchModalVisible = ref(false);
const groupPickedMedia = ref(true);

function makeLocalId() {
  return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

function revokePendingMediaUrls() {
  pendingMediaItems.value.forEach((item) => URL.revokeObjectURL(item.url));
}

function closeMediaBatchModal() {
  revokePendingMediaUrls();
  pendingMediaItems.value = [];
  mediaBatchModalVisible.value = false;
  groupPickedMedia.value = true;
}

function removePendingMediaItem(id: string) {
  const target = pendingMediaItems.value.find((item) => item.id === id);
  if (target) {
    URL.revokeObjectURL(target.url);
  }
  pendingMediaItems.value = pendingMediaItems.value.filter((item) => item.id !== id);
  if (pendingMediaItems.value.length === 0) {
    closeMediaBatchModal();
  }
}

function confirmPendingMediaItems() {
  const files = pendingMediaItems.value.map((item) => item.file);
  if (files.length === 0) {
    closeMediaBatchModal();
    return;
  }

  emit('attachPicked', {
    files,
    category: 'media',
    grouped: groupPickedMedia.value && files.length > 1,
  });

  closeMediaBatchModal();
}

function detectLocalMediaKind(file: File): 'image' | 'video' {
  return file.type.startsWith('video/') ? 'video' : 'image';
}

function messageHasMediaGrid(message: Message) {
  const attachments = message.attachments || [];
  return attachments.length > 1 && attachments.every((attachment) => attachment.kind === 'image' || attachment.kind === 'video');
}

function mediaGridClass(message: Message) {
  const count = Math.min((message.attachments || []).length, 10);
  return `count-${count}`;
}

function messageHasBareMediaGrid(message: Message) {
  return messageHasMediaGrid(message) && !message.text?.trim() && !message.forwardedFromUsername && !message.replyTo;
}



function getForwardedOriginalDateValue(message: Message): Date | null {

  const raw = (message as any)?.forwardedOriginalCreatedAt as string | null | undefined;

  if (!raw) return null;

  const value = new Date(raw);

  return Number.isNaN(value.getTime()) ? null : value;

}



function formatForwardedOriginalTime(message: Message): string {

  const value = getForwardedOriginalDateValue(message);

  if (!value) return '';

  return value.toLocaleTimeString('ru-RU', {

    hour: '2-digit',

    minute: '2-digit',

  });

}



function formatForwardedOriginalDayMonth(message: Message): string {

  const value = getForwardedOriginalDateValue(message);

  if (!value) return '';

  return value.toLocaleDateString('ru-RU', {

    day: '2-digit',

    month: '2-digit',

  });

}

function toggleAttachMenu() {
  if (!props.activeConversation || !props.canSendMessage) return;
  showAttachMenu.value = !showAttachMenu.value;
}

function closeAttachMenu() {
