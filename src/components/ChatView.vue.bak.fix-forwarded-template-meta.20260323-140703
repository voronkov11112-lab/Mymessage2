type PendingMediaItem = {
  id: string;
  file: File;
  url: string;
  kind: 'image' | 'video';
};

const pendingMediaItems = ref<PendingMediaItem[]>([]);
const mediaBatchModalVisible = ref(false);
const groupPickedMedia = ref(true);

function makeLocalId() {
  return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

function revokePendingMediaUrls() {
  pendingMediaItems.value.forEach((item) => URL.revokeObjectURL(item.url));
}

function closeMediaBatchModal() {
  revokePendingMediaUrls();
  pendingMediaItems.value = [];
  mediaBatchModalVisible.value = false;
  groupPickedMedia.value = true;
}

function removePendingMediaItem(id: string) {
  const target = pendingMediaItems.value.find((item) => item.id === id);
  if (target) {
    URL.revokeObjectURL(target.url);
  }
  pendingMediaItems.value = pendingMediaItems.value.filter((item) => item.id !== id);
  if (pendingMediaItems.value.length === 0) {
    closeMediaBatchModal();
  }
}

function confirmPendingMediaItems() {
  const files = pendingMediaItems.value.map((item) => item.file);
  if (files.length === 0) {
    closeMediaBatchModal();
    return;
  }

  emit('attachPicked', {
    files,
    category: 'media',
    grouped: groupPickedMedia.value && files.length > 1,
  });

  closeMediaBatchModal();
}

function detectLocalMediaKind(file: File): 'image' | 'video' {
  return file.type.startsWith('video/') ? 'video' : 'image';
}

function messageHasMediaGrid(message: Message) {
  const attachments = message.attachments || [];
  return attachments.length > 1 && attachments.every((attachment) => attachment.kind === 'image' || attachment.kind === 'video');
}

function mediaGridClass(message: Message) {
  const count = Math.min((message.attachments || []).length, 10);
  return `count-${count}`;
}

function messageHasBareMediaGrid(message: Message) {
  return messageHasMediaGrid(message) && !message.text?.trim() && !message.forwardedFromUsername && !message.replyTo;
}

function getForwardedOriginalDate(message: Message): Date | null {

  const raw =

    (message as any)?.forwardedOriginalCreatedAt ||

    (message as any)?.forwardedFromCreatedAt ||

    null;

  if (!raw) return null;

  const date = new Date(raw);

  return Number.isNaN(date.getTime()) ? null : date;

}

function formatForwardedOriginalTime(message: Message): string {

  const date = getForwardedOriginalDate(message);

  if (!date) return '';

  return date.toLocaleTimeString('ru-RU', {

    hour: '2-digit',

    minute: '2-digit',

  });

}

function formatForwardedOriginalDayMonth(message: Message): string {

  const date = getForwardedOriginalDate(message);

  if (!date) return '';

  const day = String(date.getDate()).padStart(2, '0');

  const month = String(date.getMonth() + 1).padStart(2, '0');

  return `${day}/${month}`;

}

function formatForwardedOriginalHeaderDate(message: Message): string {

  const date = getForwardedOriginalDate(message);

  if (!date) return '';

  const months = [

    'января',

    'февраля',

    'марта',

    'апреля',

    'мая',

    'июня',

    'июля',

    'августа',

    'сентября',

    'октября',

    'ноября',

    'декабря',

  ];

  return `${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}, ${formatForwardedOriginalTime(message)}`;

}

function formatReplyPreviewDate(value: string): string {

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) return '';

  const now = new Date();

  const sameDay =

    date.getFullYear() === now.getFullYear() &&

    date.getMonth() === now.getMonth() &&

    date.getDate() === now.getDate();

  const yesterday = new Date(now);

  yesterday.setDate(now.getDate() - 1);

  const isYesterday =

    date.getFullYear() === yesterday.getFullYear() &&

    date.getMonth() === yesterday.getMonth() &&

    date.getDate() === yesterday.getDate();

  const time = date.toLocaleTimeString('ru-RU', {

    hour: '2-digit',

    minute: '2-digit',

  });

  if (sameDay) return `сегодня, ${time}`;

  if (isYesterday) return `вчера, ${time}`;

  const day = String(date.getDate()).padStart(2, '0');

  const month = String(date.getMonth() + 1).padStart(2, '0');

  return `${day}.${month}.${date.getFullYear()}`;

}

function formatReplyForwardedDate(value: string): string {

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) return '';

  const day = String(date.getDate()).padStart(2, '0');

  const month = String(date.getMonth() + 1).padStart(2, '0');

  return `${day}.${month}.${date.getFullYear()}`;

}

function formatReplyAttachmentSize(sizeBytes?: number | null): string {

  if (!sizeBytes || sizeBytes <= 0) return '';

  const mb = sizeBytes / (1024 * 1024);

  if (mb >= 1) return `${mb.toFixed(1)} MB`;

  const kb = sizeBytes / 1024;

  if (kb >= 1) return `${Math.round(kb)} KB`;

  return `${sizeBytes} B`;

}

function formatReplyAttachmentDuration(attachment?: MessageAttachment | null): string {

  const value = Number((attachment as any)?.durationSeconds || 0);

  if (!value || Number.isNaN(value)) return '';

  const minutes = Math.floor(value / 60);

  const seconds = value % 60;

  return `${minutes}:${String(seconds).padStart(2, '0')}`;

}

function mobileReplyTitle(reply: MessageReply): string {

  if ((reply as any).forwardedFromUsername) return 'Ответ на пересланное сообщение';

  if (reply.attachmentPreview?.kind === 'image') return `Ответ на фото от ${reply.username}`;

  if (reply.attachmentPreview?.kind === 'video') return `Ответ на видео от ${reply.username}`;

  if (reply.attachmentPreview?.kind === 'audio') return `Ответ на аудио от ${reply.username}`;

  if (reply.attachmentPreview?.kind === 'file') return `Ответ на документ от ${reply.username}`;

  return `Ответ для ${reply.username}`;

}

function mobileReplySubtitle(reply: MessageReply): string {

  if ((reply as any).forwardedFromUsername) {

    const date = (reply as any).forwardedOriginalCreatedAt

      ? formatReplyForwardedDate((reply as any).forwardedOriginalCreatedAt)

      : '';

    return ['↪ Переслано от ' + (reply as any).forwardedFromUsername, date].filter(Boolean).join('  ');

  }

  if (reply.attachmentPreview) return '';

  return previewText(reply.text);

}

function mobileReplyAttachmentName(reply: MessageReply): string {

  const attachment = reply.attachmentPreview;

  return displayAttachmentName(attachment) || previewText(reply.text);

}

function mobileReplyAttachmentMeta(reply: MessageReply): string {

  const attachment = reply.attachmentPreview;

  if (!attachment) return '';

  const date = formatReplyPreviewDate(reply.createdAt);

  const size = formatReplyAttachmentSize(attachment.sizeBytes);

  const duration = formatReplyAttachmentDuration(attachment);

  if (attachment.kind === 'image' || attachment.kind === 'file') {

    return [date, size].filter(Boolean).join(' • ');

  }

  if (attachment.kind === 'video' || attachment.kind === 'audio') {

    return [date, duration].filter(Boolean).join(' • ');

  }

  return [date, size].filter(Boolean).join(' • ');

}

function mobileReplyFileBadge(reply: MessageReply): string {

  const mime = reply.attachmentPreview?.mimeType?.toLowerCase() || '';

  const name = reply.attachmentPreview?.originalName?.toLowerCase() || '';

  if (mime.includes('pdf') || name.endsWith('.pdf')) return 'PDF';

  if (

    mime.includes('word') ||

    name.endsWith('.doc') ||

    name.endsWith('.docx') ||

    name.endsWith('.odt') ||

    name.endsWith('.rtf')

  ) return 'DOC';

  if (

    mime.includes('excel') ||

    mime.includes('spreadsheet') ||

    name.endsWith('.xls') ||

    name.endsWith('.xlsx') ||

    name.endsWith('.csv') ||

    name.endsWith('.ods')

  ) return 'XLS';

  if (

    mime.includes('html') ||

    name.endsWith('.html') ||

    name.endsWith('.htm')

  ) return 'HTML';

  if (

    mime.includes('text/plain') ||

    name.endsWith('.txt') ||

    name.endsWith('.md') ||

    name.endsWith('.log')

  ) return 'TXT';

  if (

    mime.includes('text/css') ||

    name.endsWith('.css') ||

    name.endsWith('.scss') ||

    name.endsWith('.less')

  ) return 'CSS';

  if (

    mime.includes('javascript') ||

    mime.includes('json') ||

    mime.includes('typescript') ||

    name.endsWith('.js') ||

    name.endsWith('.mjs') ||

    name.endsWith('.cjs') ||

    name.endsWith('.ts') ||

    name.endsWith('.tsx') ||

    name.endsWith('.json')

  ) return 'JS';

  return 'FILE';

}

