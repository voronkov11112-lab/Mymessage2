function forwardedOriginalText(message: Message): string {

  const source = forwardedSourceBodyText(message);

  if (source) return source;

  return (message.text || '').trim();

}

function forwardedOriginalHasText(message: Message): boolean {

  return !!forwardedOriginalText(message);

}

function hasForwardComment(message: Message): boolean {

  if (!message.forwardedFromUsername) return false;

  const current = (message.text || '').trim();

  if (!current) return false;

  const hasForwardedSourceField = Object.prototype.hasOwnProperty.call(message, 'forwardedSourceText');

  if (!hasForwardedSourceField) return false;

  const source = ((message as any).forwardedSourceText || '').trim();

  return current !== source;

}

function forwardCommentText(message: Message): string {

  return hasForwardComment(message) ? (message.text || '').trim() : '';

}

function normalizeAttachmentName(raw: string | null | undefined): string {

  const input = (raw || '').trim();

  if (!input) return '';

  const suspicious = /[ÐÑÃâ]/.test(input);

  if (!suspicious) {

    return input.replace(/\s+/g, ' ').trim();

  }

  try {

    const bytes = Uint8Array.from(Array.from(input).map((ch) => ch.charCodeAt(0) & 0xff));

    const decoded = new TextDecoder('utf-8', { fatal: false }).decode(bytes);

    if (

      decoded &&

      decoded !== input &&

      !decoded.includes('�') &&

      /[А-Яа-яЁё]/.test(decoded)

    ) {

      return decoded.replace(/\s+/g, ' ').trim();

    }

  } catch {}

  return input.replace(/\s+/g, ' ').trim();

}

function displayAttachmentName(attachment: MessageAttachment | null | undefined): string {

  return normalizeAttachmentName(attachment?.originalName);

}

function forwardedImageOnly(message: Message): boolean {

  if (!message.forwardedFromUsername) return false;

  if (message.replyTo) return false;

  if (hasForwardComment(message)) return false;

  if (forwardedOriginalHasText(message)) return false;

  const attachments = message.attachments || [];

  return attachments.length === 1 && attachments[0]?.kind === 'image';

}

function attachmentUrl(relativeUrl: string) {
  if (!relativeUrl) return '';

