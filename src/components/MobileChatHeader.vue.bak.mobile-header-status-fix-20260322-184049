
<script setup lang="ts">

type Conversation = {

  id: string;

  type: 'direct' | 'group' | 'channel';

  title: string | null;

};



const props = defineProps<{

  activeConversation: Conversation | null;

  presenceText?: string;

  isOnline?: boolean;

  isTyping?: boolean;

}>();



const emit = defineEmits<{

  back: [];

  openInfo: [];

}>();



function titleLabel() {

  if (!props.activeConversation) return 'Чаты';

  return props.activeConversation.title || 'Без названия';

}



function isDirectChat() {

  return props.activeConversation?.type === 'direct';

}



function subtitleLabel() {

  if (!props.activeConversation) return '';



  if (props.activeConversation.type === 'direct') return 'онлайн';

  if (props.activeConversation.type === 'group') return 'Группа';

  return 'Канал';

}



function initials(value: string) {

  return value.trim().charAt(0).toUpperCase();

}

</script>



